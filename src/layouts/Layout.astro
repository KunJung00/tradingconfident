---
interface Props {
  title: string;
  dataTheme?: string;
}
const { title, dataTheme } = Astro.props;
---
<!doctype html>
<html lang="th" {...(dataTheme ? { 'data-theme': dataTheme } : {})}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
