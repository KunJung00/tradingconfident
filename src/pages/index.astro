---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Trading Tools">
  <div class="min-h-screen bg-gradient-to-br from-slate-900 to-slate-800 flex flex-col items-center justify-center p-8">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-white mb-2 tracking-tight">Trading Tools</h1>
      <p class="text-slate-400">เครื่องมือช่วยเทรดด้วยสติและวินัย</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl w-full">
      <a
        href="/pre-trade-check"
        class="bg-white/10 hover:bg-white/15 border border-white/20 rounded-2xl p-8 text-white transition-all duration-200"
      >
        <div class="text-4xl mb-4">🧘</div>
        <h2 class="text-xl font-semibold mb-2">Pre-Trade Check</h2>
        <p class="text-slate-400 text-sm leading-relaxed">
          เช็กสติก่อนเทรด 5 คำถามสำคัญ<br />ตอบได้ครบ ค่อยเปิดกราฟ
        </p>
      </a>
      <a
        href="/simulator"
        class="bg-white/10 hover:bg-white/15 border border-white/20 rounded-2xl p-8 text-white transition-all duration-200"
      >
        <div class="text-4xl mb-4">📊</div>
        <h2 class="text-xl font-semibold mb-2">EdgeIQ Simulator</h2>
        <p class="text-slate-400 text-sm leading-relaxed">
          Monte Carlo 500 simulation paths<br />ทดสอบระบบเทรดด้วยสถิติ
        </p>
      </a>
    </div>
  </div>
</Layout>
